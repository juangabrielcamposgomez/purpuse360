# ----------------------------------------------------------------------------
# Purpose360 AI - Unified Environment Configuration
# Copy: cp .env.example .env
# ----------------------------------------------------------------------------

# --- 1. SUPABASE (Backend & Database) ---
# Get these from: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Get this from: Settings > Database > Connection string > URI
# Format: postgresql://postgres.[ID]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=your-database-connection-string

# --- 2. AI MODELS (The Brain) ---
# Gemini: https://aistudio.google.com
GEMINI_API_KEY=your-gemini-key

# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key

# Agent Runtime: gemini-flash-deep | gemini-flash-react | claude-sonnet-4-6-react
AGENT_RUNTIME=gemini-flash-deep

# --- 3. COPILOTKIT & INTELLIGENCE ---
# Get a license: npm run license
COPILOTKIT_LICENSE_TOKEN=your-license-token

# Intelligence URLs (Managed threads)
INTELLIGENCE_API_URL=http://localhost:4203
INTELLIGENCE_GATEWAY_WS_URL=ws://localhost:4403
INTELLIGENCE_API_KEY=cpk_sPRVSEED_seed0privat0longtoken00

# --- 4. AGENTS & TOOLS ---
# LangGraph Agent (Python)
LANGGRAPH_DEPLOYMENT_URL=http://localhost:8133
# Individual deployments for multi-model switching (BFF use)
LANGGRAPH_DEPLOYMENT_URL_GEMINI=http://localhost:8123
LANGGRAPH_DEPLOYMENT_URL_CLAUDE=http://localhost:8133

# MCP Server (mcp-use)
MCP_SERVER_URL=http://localhost:3001/mcp

# --- 5. INTEGRATIONS (Notion) ---
# https://notion.so/my-integrations
NOTION_TOKEN=your-notion-token
NOTION_LEADS_DATABASE_ID=your-database-id

# --- 6. INFRASTRUCTURE PORTS (Docker) ---
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6381
APP_API_HOST_PORT=4203
REALTIME_GATEWAY_HOST_PORT=4403

# --- 7. OPTIONAL TUNING ---
THREAD_STALE_HOURS=3
THREAD_CULL_BATCH_SIZE=1000
